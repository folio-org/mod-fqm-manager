<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">
  <!-- Trillium -->
  <changeSet id="create_view_consortia_tenant" author="bsharp@ebsco.com" runAlways="true">
    <preConditions onFail="CONTINUE">
      <tableExists tableName="tenant" schemaName="${tenant_id}_mod_consortia_keycloak"/>
    </preConditions>
    <createView
      replaceIfExists="true"
      viewName="src_consortia_tenant">
      SELECT * FROM ${tenant_id}_mod_consortia_keycloak.tenant
    </createView>
  </changeSet>


</databaseChangeLog>
