// This simple ET exposes one row per (invoice line, fund distribution) pair, sourced from the dedicated
// 'src_invoice_line_fund_distributions' DB view which already pre-joins invoice_lines with the
// lateral expansion of the 'fundDistributions' jsonb array. Keeping the lateral expansion in the
// view (instead of in the entity itself) lets us model this as a single-source entity with
// straightforward column definitions.
{
  id: '4999bd5f-3898-4b44-b283-e37bc9261ad8',
  name: 'composite_invoice_line_fund_distribution',
  private: true,
  requiredPermissions: [
    'invoice.invoice-lines.collection.get',
    'invoice.invoices.collection.get',
    'orders.po-lines.item.get',
  ],
  sources: [
    {
      type: 'db',
      alias: 'invoice_line_fund_distributions',
      target: 'src_invoice_line_fund_distributions',
    },
  ],
  columns: [
    {
      name: 'invoice_line_id',
      sourceAlias: 'invoice_line_fund_distributions',
      dataType: {
        dataType: 'rangedUUIDType',
      },
      isIdColumn: true,
      queryable: true,
      valueGetter: ':sourceAlias.id',
      joinsTo: [
        {
          targetId: '1373f063-8b86-48cc-832d-68b4d0dd44fc', // simple_invoice_line
          targetField: 'id',
          type: 'equality-simple',
          direction: 'left',
        },
      ],
    },
    {
      name: 'invoice_id',
      sourceAlias: 'invoice_line_fund_distributions',
      dataType: {
        dataType: 'rangedUUIDType',
      },
      queryable: true,
      valueGetter: ':sourceAlias.invoice_id',
      joinsTo: [
        {
          targetId: '4d626ce1-1880-48d2-9d4c-81667fdc5dbb', // simple_invoice
          targetField: 'id',
          type: 'equality-simple',
          direction: 'left',
        },
      ],
    },
    {
      name: 'po_line_id',
      sourceAlias: 'invoice_line_fund_distributions',
      dataType: {
        dataType: 'rangedUUIDType',
      },
      queryable: true,
      valueGetter: "(:sourceAlias.jsonb->>'poLineId')::uuid",
      joinsTo: [
        {
          targetId: '58148257-bfb0-4687-8c42-d2833d772f3e', // simple_purchase_order_line
          targetField: 'id',
          type: 'equality-simple',
          direction: 'left',
        },
      ],
    },
    {
      name: 'fund_id',
      sourceAlias: 'invoice_line_fund_distributions',
      dataType: {
        dataType: 'rangedUUIDType',
      },
      isIdColumn: true,
      queryable: true,
      valueGetter: "(:sourceAlias.fund_distribution->>'fundId')::uuid",
      joinsTo: [
        {
          targetId: '4c63c7f5-1a28-4394-b401-98c02c31492d', // simple_fund
          targetField: 'id',
          type: 'equality-simple',
          direction: 'left',
        },
      ],
    },
    {
      name: 'expense_class_id',
      sourceAlias: 'invoice_line_fund_distributions',
      dataType: {
        dataType: 'rangedUUIDType',
      },
      queryable: true,
      valueGetter: "(:sourceAlias.fund_distribution->>'expenseClassId')::uuid",
      joinsTo: [
        {
          targetId: '6e11cd39-a34e-4afc-90db-957dd45d139e', // simple_expense_class
          targetField: 'id',
          type: 'equality-simple',
          direction: 'left',
        },
      ],
    },
    {
      name: 'fund_total_value',
      sourceAlias: 'invoice_line_fund_distributions',
      dataType: {
        dataType: 'stringType',
      },
      valueGetter: "(\
        CASE WHEN (:sourceAlias.fund_distribution->>'distributionType') = 'percentage' \
          THEN (:sourceAlias.fund_distribution->>'value') || '%' \
          ELSE (:sourceAlias.fund_distribution->>'value') \
        END \
      )",
      queryable: false,
      visibleByDefault: true,
      essential: true,
    },
    {
      name: 'fund_total_amount',
      sourceAlias: 'invoice_line_fund_distributions',
      dataType: {
        dataType: 'stringType',
      },
      valueGetter: "(\
        CASE WHEN (:sourceAlias.fund_distribution->>'distributionType') = 'amount' \
          THEN (:sourceAlias.fund_distribution->>'value') \
          ELSE NULL \
        END \
      )",
      queryable: false,
      visibleByDefault: true,
      essential: true,
    },
  ],
}
