  sources: [
    {
      alias: 'charge',
      type: 'db',
      target: 'src_oa_charge',
    },
    {
      type: 'db',
      alias: 'monetary_value',
      target: 'src_oa_monetary_value',
      join: {
        type: 'left join',
        joinTo: 'charge',
        condition: ':this.id = :that.ch_amount_fk',
      },
    },
    {
      type: 'db',
      alias: 'exchange_rate',
      target: 'src_oa_exchange_rate',
      join: {
        type: 'left join',
        joinTo: 'charge',
        condition: ':this.id = :that.ch_exchange_rate_fk',
      },
    },
