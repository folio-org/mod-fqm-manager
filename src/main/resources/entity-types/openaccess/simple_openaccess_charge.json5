      type: 'db',
      alias: 'discount_type',
      target: 'src_oa_refdata_value',
      join: {
        type: 'left join',
        joinTo: 'charge',
        condition: ':this.rdv_id = :that.ch_discount_type_fk',
      },
    },
    {
      type: 'db',
      alias: 'category',
      target: 'src_oa_refdata_value',
      join: {
        type: 'left join',
        joinTo: 'charge',
        condition: ':this.rdv_id = :that.ch_category_fk',
      },
    },
