        dataType: 'stringType',
      },
      queryable: true,
      valueGetter: ':prc_mode.rdv_value',
    },
    {
      name: 'correspondence_mode_label',
      dataType: {
        dataType: 'stringType',
      },
      queryable: true,
      visibleByDefault: true,
      valueGetter: ':prc_mode.rdv_label',
