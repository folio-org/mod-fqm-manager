              ],
              valueGetter: "(SELECT array_agg(elems.value->>'itemClaimedReturned') FROM jsonb_array_elements(:src__circulation__patron_blocks__user_summary.jsonb->'openLoans') AS elems)",
              filterValueGetter: "(SELECT array_agg(lower(elems.value->>'itemClaimedReturned')) FROM jsonb_array_elements(:src__circulation__patron_blocks__user_summary.jsonb->'openLoans') AS elems)",
              valueFunction: 'lower(:value)',
              property: 'itemClaimedReturned',
              dataType: {
                dataType: 'booleanType',
              },
            },
            {
              name: 'grace_period',
              queryable: false,
              hidden: true,
              valueGetter: "(SELECT array_agg(elems.value->>'gracePeriod') FROM jsonb_array_elements(:src__circulation__patron_blocks__user_summary.jsonb->'openLoans') AS elems)",
              filterValueGetter: "(SELECT array_agg(lower(elems.value->>'gracePeriod')) FROM jsonb_array_elements(:src__circulation__patron_blocks__user_summary.jsonb->'openLoans') AS elems)",
              valueFunction: 'lower(:value)',
              property: 'gracePeriod',
              dataType: {
                dataType: 'objectType',
                properties: [
                  {
                    name: 'duration',
                    queryable: false,
                    valueGetter: "(:src__circulation__patron_blocks__user_summary.jsonb->'openLoans'->'gracePeriod'->>'duration')::integer",
                    valueFunction: '(:value)::integer',
                    property: 'duration',
                    dataType: {
                      dataType: 'integerType',
                    },
                  },
                  {
                    name: 'interval_id',
                    queryable: true,
                    values: [
                      {
                        value: 'Minutes',
                        label: 'Minutes',
                      },
                      {
                        value: 'Hours',
                        label: 'Hours',
                      },
                      {
                        value: 'Days',
                        label: 'Days',
                      },
                      {
                        value: 'Weeks',
                        label: 'Weeks',
                      },
                      {
                        value: 'Months',
                        label: 'Months',
                      },
                    ],
                    valueGetter: ":src__circulation__patron_blocks__user_summary.jsonb->'openLoans'->'gracePeriod'->>'intervalId'",
                    property: 'intervalId',
                    dataType: {
                      dataType: 'stringType',
                    },
                  },
                ],
              },
            },
          ],
        },
      },
      queryable: false,
      visibleByDefault: true,
      valueGetter: ":src__circulation__patron_blocks__user_summary.jsonb->>'openLoans'",
      sourceAlias: 'src__circulation__patron_blocks__user_summary',
      filterValueGetter: "lower(${tenant_id}_mod_patron_blocks.f_unaccent(:src__circulation__patron_blocks__user_summary.jsonb->>'openLoans'::text))",
      valueFunction: 'lower(${tenant_id}_mod_patron_blocks.f_unaccent(:value))',
      essential: true,
    },
    {
      name: 'open_fees_fines',
      dataType: {
        dataType: 'arrayType',
        itemDataType: {
          dataType: 'objectType',
          properties: [
            {
              name: 'fee_fine_id',
              queryable: true,
              valueGetter: "(SELECT array_agg((elems.value->>'feeFineId')::uuid) FROM jsonb_array_elements(:src__circulation__patron_blocks__user_summary.jsonb->'openFeesFines') AS elems)",
              valueFunction: '(:value)::uuid',
              property: 'feeFineId',
              dataType: {
                dataType: 'rangedUUIDType',
              },
            },
            {
              name: 'fee_fine_type_id',
              queryable: true,
              valueSourceApi: {
                path: 'feefines',
                labelJsonPath: '$.feefines.*.feeFineType',
                valueJsonPath: '$.feefines.*.id',
              },
              source: {
                columnName: 'open_fees_fines[*]->fee_fine_type_id',
                entityTypeId: 'f5443525-d2a9-5e59-8f4a-4ac526ec8528',
              },
              property: 'feeFineType',
              valueGetter: "(SELECT array_agg(fee_fine_type.value->>'feeFineTypeId' ORDER BY fee_fine_type.value->>'feeFineTypeId') FROM jsonb_array_elements(:src__circulation__patron_blocks__user_summary.jsonb->'openFeesFines') AS fee_fine_type)",
              filterValueGetter: "(SELECT array_agg(fee_fine_type.value->>'feeFineTypeId' ORDER BY fee_fine_type.value->>'feeFineTypeId') FROM jsonb_array_elements(:src__circulation__patron_blocks__user_summary.jsonb->'openFeesFines') AS fee_fine_type)",
              valueFunction: 'lower(:value)',
              dataType: {
                dataType: 'stringType',
              },
            },
            {
              name: 'loan_id',
              queryable: true,
              valueGetter: "(SELECT array_agg((elems.value->>'loanId')::uuid) FROM jsonb_array_elements(:src__circulation__patron_blocks__user_summary.jsonb->'openFeesFines') AS elems)",
              valueFunction: '(:value)::uuid',
              property: 'loanId',
              dataType: {
                dataType: 'rangedUUIDType',
              },
            },
            {
              name: 'balance',
              queryable: false,
              valueGetter: "(SELECT array_agg((elems.value->>'balance')::float) FROM jsonb_array_elements(:src__circulation__patron_blocks__user_summary.jsonb->'openFeesFines') AS elems)",
              valueFunction: '(:value)::float',
              property: 'balance',
              dataType: {
                dataType: 'numberType',
              },
            },
          ],
        },
      },
      queryable: false,
      visibleByDefault: true,
      valueGetter: "( SELECT jsonb_agg( record.value || jsonb_build_object('feeFineType', fee_fine_type.jsonb ->> 'feeFineType') ORDER BY record.value ->> 'feeFineTypeId') FROM jsonb_array_elements((:sourceAlias.jsonb -> 'openFeesFines')) record(value) LEFT JOIN ${tenant_id}_mod_fqm_manager.src__circulation__feesfines__feefines fee_fine_type ON (record.value ->> 'feeFineTypeId') = fee_fine_type.id::text)::text",
      sourceAlias: 'src__circulation__patron_blocks__user_summary',
      essential: true,
    },
    {
      name: 'jsonb',
      dataType: {
        dataType: 'stringType',
      },
      isIdColumn: false,
      essential: true,
      hidden: true,
      queryable: false,
      visibleByDefault: false,
      valueGetter: ':src__circulation__patron_blocks__user_summary.jsonb::text',
    },
    // New columns here
    // 2 ways: sum all rows from original fee_fine table, or sum from the open_fees_fines array in the summary table.
    // AI said this, but idk: The former is more expensive but more accurate, as it would include any fees/fines that were paid off and thus not included in the open_fees_fines array
    {
      name: 'open_fees_fines_count',
      dataType: {
        dataType: 'integerType',
      },
      queryable: true,
      visibleByDefault: false,
      essential: true,
      valueGetter: "COALESCE(jsonb_array_length(:src__circulation__patron_blocks__user_summary.jsonb->'openFeesFines'), 0)",
      valueFunction: '(:value)::int',
      sourceAlias: 'src__circulation__patron_blocks__user_summary',
    },
    {
      name: 'open_loans_count',
      dataType: {
        dataType: 'integerType',
      },
      queryable: true,
      visibleByDefault: false,
      essential: true,
      valueGetter: "COALESCE(jsonb_array_length(:src__circulation__patron_blocks__user_summary.jsonb->'openLoans'), 0)",
      valueFunction: '(:value)::int',
      sourceAlias: 'src__circulation__patron_blocks__user_summary',
    },
    {
      name: 'requests_count',
      dataType: {
        dataType: 'integerType',
      },
      queryable: true,
      visibleByDefault: false,
      essential: true,
      // TODO: update to use FQM view instead of original requests table
      // TODO: requester_id or user barcode? I think requester_id
      valueGetter: "( \
        SELECT \
          COUNT(*) \
        FROM \
          ${tenant_id}_mod_fqm_manager.src__circulation_storage__request \
        WHERE \
          jsonb ->> 'requesterId' = :src__circulation__patron_blocks__user_summary.jsonb ->> 'userId' \
      )",
      valueFunction: '(:value)::int',
      sourceAlias: 'src__circulation__patron_blocks__user_summary',
    },
    {
      name: 'proxies_count',
      dataType: {
        dataType: 'integerType',
      },
      queryable: true,
      visibleByDefault: false,
      essential: true,
      valueGetter: "( \
        SELECT \
          COUNT(*) \
        FROM \
          ${tenant_id}_mod_fqm_manager.src_users_proxyfor \
        WHERE \
          jsonb ->> 'userId' = :src__circulation__patron_blocks__user_summary.jsonb ->> 'userId' \
        OR \
          jsonb ->> 'proxyUserId' = :src__circulation__patron_blocks__user_summary.jsonb ->> 'userId'\
      )",
      valueFunction: '(:value)::int',
      sourceAlias: 'src__circulation__patron_blocks__user_summary',
    },
    {
      name: 'manual_blocks_count',
      dataType: {
        dataType: 'integerType',
      },
      queryable: true,
      visibleByDefault: false,
      essential: true,
      valueGetter: "( \
        SELECT \
          COUNT(*) \
        FROM \
          ${tenant_id}_mod_fqm_manager.src__circulation__feesfines__manualblocks mb \
        WHERE \
          mb.jsonb ->> 'userId' = :src__circulation__patron_blocks__user_summary.jsonb ->> 'userId' \
          AND ( \
            mb.jsonb ->> 'expirationDate' IS NULL \
            OR (mb.jsonb ->> 'expirationDate')::timestamptz > current_timestamp \
          ) \
      )",
      valueFunction: '(:value)::int',
      sourceAlias: 'src__circulation__patron_blocks__user_summary',
    },
    {
      name: 'automated_blocks_count',
      dataType: {
        dataType: 'integerType',
      },
      queryable: true,
      visibleByDefault: false,
      essential: true,
      valueGetter: "( \
        SELECT \
          COUNT(*) \
        FROM \
          ${tenant_id}_mod_fqm_manager.src__circulation__patron_blocks__patron_block_limits limits \
          JOIN ${tenant_id}_mod_fqm_manager.src__circulation__patron_blocks__patron_block_conditions conditions \
            ON conditions.id = (limits.jsonb ->> 'conditionId')::uuid \
          JOIN ${tenant_id}_mod_fqm_manager.src_users_users users \
            ON users.id = (:src__circulation__patron_blocks__user_summary.jsonb ->> 'userId')::uuid \
        WHERE \
          limits.jsonb ->> 'patronGroupId' = users.jsonb ->> 'patronGroup' \
          AND CASE \
            WHEN conditions.id = '3d7c52dc-c732-4223-8bf8-e5917801386f'::uuid THEN \
              COALESCE(jsonb_array_length(:src__circulation__patron_blocks__user_summary.jsonb -> 'openLoans'), 0) > (limits.jsonb ->> 'value')::numeric \
            WHEN conditions.id = '584fbd4f-6a34-4730-a6ca-73a6a6a9d845'::uuid THEN \
              ( \
                SELECT \
                  COUNT(*) \
                FROM \
                  jsonb_array_elements(COALESCE(:src__circulation__patron_blocks__user_summary.jsonb -> 'openLoans', '[]'::jsonb)) AS loan(value) \
                WHERE \
                  (loan.value ->> 'dueDate')::timestamptz < current_timestamp \
              ) > (limits.jsonb ->> 'value')::numeric \
            WHEN conditions.id = 'e5b45031-a202-4abb-917b-e1df9346fe2c'::uuid THEN \
              ( \
                SELECT \
                  COUNT(*) \
                FROM \
                  jsonb_array_elements(COALESCE(:src__circulation__patron_blocks__user_summary.jsonb -> 'openLoans', '[]'::jsonb)) AS loan(value) \
                WHERE \
                  loan.value ->> 'recall' = 'true' \
                  AND (loan.value ->> 'dueDate')::timestamptz < current_timestamp \
              ) > (limits.jsonb ->> 'value')::numeric \
            WHEN conditions.id = '08530ac4-07f2-48e6-9dda-a97bc2bf7053'::uuid THEN \
              EXISTS ( \
                SELECT \
                  1 \
                FROM \
                  jsonb_array_elements(COALESCE(:src__circulation__patron_blocks__user_summary.jsonb -> 'openLoans', '[]'::jsonb)) AS loan(value) \
                WHERE \
                  loan.value ->> 'recall' = 'true' \
                  AND (loan.value ->> 'dueDate')::timestamptz < current_timestamp - ((limits.jsonb ->> 'value')::numeric::text || ' days')::interval \
              ) \
            WHEN conditions.id = '72b67965-5b73-4840-bc0b-be8f3f6e047e'::uuid THEN \
              ( \
                SELECT \
                  COUNT(*) \
                FROM \
                  jsonb_array_elements(COALESCE(:src__circulation__patron_blocks__user_summary.jsonb -> 'openLoans', '[]'::jsonb)) AS loan(value) \
                WHERE \
                  loan.value ->> 'itemLost' = 'true' \
              ) > (limits.jsonb ->> 'value')::numeric \
            WHEN conditions.id = 'cf7a0d5f-a327-4ca1-aa9e-dc55ec006b8a'::uuid THEN \
              ( \
                SELECT \
                  COALESCE(SUM((fee_fine.value ->> 'balance')::numeric), 0) \
                FROM \
                  jsonb_array_elements(COALESCE(:src__circulation__patron_blocks__user_summary.jsonb -> 'openFeesFines', '[]'::jsonb)) AS fee_fine(value) \
              ) > (limits.jsonb ->> 'value')::numeric \
            ELSE false \
          END \
      )",
      valueFunction: '(:value)::int',
      sourceAlias: 'src__circulation__patron_blocks__user_summary',
    },
    {
      name: 'has_open_transactions',
      dataType: {
        dataType: 'booleanType',
      },
      queryable: true,
      visibleByDefault: false,
      essential: true,
      valueGetter: "( \
        COALESCE(jsonb_array_length(:src__circulation__patron_blocks__user_summary.jsonb -> 'openFeesFines'), 0) > 0 \
        OR COALESCE(jsonb_array_length(:src__circulation__patron_blocks__user_summary.jsonb -> 'openLoans'), 0) > 0 \
        OR EXISTS ( \
          SELECT \
            1 \
          FROM \
            ${tenant_id}_mod_fqm_manager.src__circulation_storage__request request \
          WHERE \
            request.jsonb ->> 'requesterId' = :src__circulation__patron_blocks__user_summary.jsonb ->> 'userId' \
        ) \
        OR EXISTS ( \
          SELECT \
            1 \
          FROM \
            ${tenant_id}_mod_fqm_manager.src_users_proxyfor proxyfor \
          WHERE \
            proxyfor.jsonb ->> 'userId' = :src__circulation__patron_blocks__user_summary.jsonb ->> 'userId' \
            OR proxyfor.jsonb ->> 'proxyUserId' = :src__circulation__patron_blocks__user_summary.jsonb ->> 'userId' \
        ) \
        OR EXISTS ( \
          SELECT \
            1 \
          FROM \
            ${tenant_id}_mod_fqm_manager.src__circulation__feesfines__manualblocks mb \
          WHERE \
            mb.jsonb ->> 'userId' = :src__circulation__patron_blocks__user_summary.jsonb ->> 'userId' \
            AND ( \
              mb.jsonb ->> 'expirationDate' IS NULL \
              OR (mb.jsonb ->> 'expirationDate')::timestamptz > current_timestamp \
            ) \
        ) \
        OR EXISTS ( \
          SELECT \
            1 \
          FROM \
            ${tenant_id}_mod_fqm_manager.src__circulation__patron_blocks__patron_block_limits limits \
            JOIN ${tenant_id}_mod_fqm_manager.src__circulation__patron_blocks__patron_block_conditions conditions \
              ON conditions.id = (limits.jsonb ->> 'conditionId')::uuid \
            JOIN ${tenant_id}_mod_fqm_manager.src_users_users users \
              ON users.id = (:src__circulation__patron_blocks__user_summary.jsonb ->> 'userId')::uuid \
          WHERE \
            limits.jsonb ->> 'patronGroupId' = users.jsonb ->> 'patronGroup' \
            AND CASE \
              WHEN conditions.id = '3d7c52dc-c732-4223-8bf8-e5917801386f'::uuid THEN \
                COALESCE(jsonb_array_length(:src__circulation__patron_blocks__user_summary.jsonb -> 'openLoans'), 0) > (limits.jsonb ->> 'value')::numeric \
              WHEN conditions.id = '584fbd4f-6a34-4730-a6ca-73a6a6a9d845'::uuid THEN \
                ( \
                  SELECT \
                    COUNT(*) \
                  FROM \
                    jsonb_array_elements(COALESCE(:src__circulation__patron_blocks__user_summary.jsonb -> 'openLoans', '[]'::jsonb)) AS loan(value) \
                  WHERE \
                    (loan.value ->> 'dueDate')::timestamptz < current_timestamp \
                ) > (limits.jsonb ->> 'value')::numeric \
              WHEN conditions.id = 'e5b45031-a202-4abb-917b-e1df9346fe2c'::uuid THEN \
                ( \
                  SELECT \
                    COUNT(*) \
                  FROM \
                    jsonb_array_elements(COALESCE(:src__circulation__patron_blocks__user_summary.jsonb -> 'openLoans', '[]'::jsonb)) AS loan(value) \
                  WHERE \
                    loan.value ->> 'recall' = 'true' \
                    AND (loan.value ->> 'dueDate')::timestamptz < current_timestamp \
                ) > (limits.jsonb ->> 'value')::numeric \
              WHEN conditions.id = '08530ac4-07f2-48e6-9dda-a97bc2bf7053'::uuid THEN \
                EXISTS ( \
                  SELECT \
                    1 \
                  FROM \
                    jsonb_array_elements(COALESCE(:src__circulation__patron_blocks__user_summary.jsonb -> 'openLoans', '[]'::jsonb)) AS loan(value) \
                  WHERE \
                    loan.value ->> 'recall' = 'true' \
                    AND (loan.value ->> 'dueDate')::timestamptz < current_timestamp - ((limits.jsonb ->> 'value')::numeric::text || ' days')::interval \
                ) \
              WHEN conditions.id = '72b67965-5b73-4840-bc0b-be8f3f6e047e'::uuid THEN \
                ( \
                  SELECT \
                    COUNT(*) \
                  FROM \
                    jsonb_array_elements(COALESCE(:src__circulation__patron_blocks__user_summary.jsonb -> 'openLoans', '[]'::jsonb)) AS loan(value) \
                  WHERE \
                    loan.value ->> 'itemLost' = 'true' \
                ) > (limits.jsonb ->> 'value')::numeric \
              WHEN conditions.id = 'cf7a0d5f-a327-4ca1-aa9e-dc55ec006b8a'::uuid THEN \
                ( \
                  SELECT \
                    COALESCE(SUM((fee_fine.value ->> 'balance')::numeric), 0) \
                  FROM \
                    jsonb_array_elements(COALESCE(:src__circulation__patron_blocks__user_summary.jsonb -> 'openFeesFines', '[]'::jsonb)) AS fee_fine(value) \
                ) > (limits.jsonb ->> 'value')::numeric \
              ELSE false \
            END \
        ) \
      )",
      valueFunction: '(:value)::boolean',
      sourceAlias: 'src__circulation__patron_blocks__user_summary',
    },

//    {
